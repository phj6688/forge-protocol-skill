#!/usr/bin/env bash
set -euo pipefail

# FORGE CLI v3 — Autonomous Agent Delegation Protocol
# All state lives in .forge/ (gitignored). Git history stays clean.

FORGE_VERSION="3.0.0"
FORGE_DIR=".forge"
SESSIONS_DIR="$FORGE_DIR/sessions"
STATE_FILE="$FORGE_DIR/state.json"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

usage() {
    cat << EOF
${BOLD}FORGE v${FORGE_VERSION}${NC} — Autonomous Agent Delegation Protocol

${BOLD}Usage:${NC} forge <command> [options]

${BOLD}Commands:${NC}
  ${CYAN}init${NC} [dir]              Initialize a FORGE project (.forge/ directory)
  ${CYAN}audit${NC}                   Generate audit prompt
  ${CYAN}risk${NC}                    Generate risk speculation prompt (greenfield)
  ${CYAN}prompt${NC} <N>              Generate session N prompt from spec + audit
  ${CYAN}gate${NC} <N>                Run verification gates for session N
  ${CYAN}merge${NC} <N>               Merge session N branch to dev and tag
  ${CYAN}status${NC}                  Show project status
  ${CYAN}scar${NC} add <text>         Add a scar
  ${CYAN}scar${NC} prune              Archive old scars
  ${CYAN}validate${NC}               Validate TASKSPEC.md structure
  ${CYAN}version${NC}                 Show version

${BOLD}Workflow:${NC}
  1. forge init my-project     # scaffold .forge/
  2. Edit .forge/TASKSPEC.md    # write the spec
  3. forge audit                # or 'forge risk' for greenfield
  4. forge prompt 1             # generate session 1 prompt
  5. Agent executes autonomously
  6. forge gate 1               # verify locally (optional — agent already ran gates)
  7. forge merge 1              # merge to dev + tag
  8. forge prompt 2             # next session

${DIM}Shape it once. Strike until it holds.${NC}
EOF
}

require_forge() {
    if [ ! -d "$FORGE_DIR" ]; then
        echo -e "${RED}Not a FORGE project. Run 'forge init' first.${NC}"
        exit 1
    fi
}

require_spec() {
    if [ ! -f "$FORGE_DIR/TASKSPEC.md" ]; then
        echo -e "${RED}No TASKSPEC.md found in .forge/. Write the spec first.${NC}"
        exit 1
    fi
}

# Extract session info from TASKSPEC.md Build Order
# Returns: title, branch, tag for session N
get_session_info() {
    local n="$1"
    local spec="$FORGE_DIR/TASKSPEC.md"
    local in_session=0
    local title="" branch="" tag=""

    while IFS= read -r line; do
        if echo "$line" | grep -qP "^### Session ${n}:"; then
            in_session=1
            title=$(echo "$line" | sed "s/^### Session ${n}: //")
            continue
        fi
        if [ $in_session -eq 1 ]; then
            if echo "$line" | grep -qP "^### Session"; then
                break
            fi
            if echo "$line" | grep -qP "^\*\*Branch:\*\*"; then
                branch=$(echo "$line" | sed 's/.*\*\*Branch:\*\* *//' | tr -d '`')
            fi
            if echo "$line" | grep -qP "^\*\*Tag:\*\*"; then
                tag=$(echo "$line" | sed 's/.*\*\*Tag:\*\* *//' | tr -d '`')
            fi
        fi
    done < "$spec"

    echo "$title|$branch|$tag"
}

cmd_init() {
    local dir="${1:-.}"

    if [ "$dir" != "." ]; then
        mkdir -p "$dir"
        cd "$dir"
    fi

    echo -e "${BOLD}Initializing FORGE project in $(pwd)${NC}"

    # Create .forge structure
    mkdir -p "$FORGE_DIR/sessions"

    # TASKSPEC template
    if [ ! -f "$FORGE_DIR/TASKSPEC.md" ]; then
        cat > "$FORGE_DIR/TASKSPEC.md" << 'SPEC'
# [PROJECT NAME] -- TASKSPEC

## Provenance
| Field | Value |
|-------|-------|
| Date | YYYY-MM-DD |
| Codebase | greenfield |
| Spec Version | v1.0 |

## Mission
[What this project does and why.]

## Stack
| Layer | Technology | Version | Rationale |
|-------|-----------|---------|-----------|

## Directory Structure
[Full tree]

## Data Model
[Schemas, types, relationships]

## Features

### Feature 1: [Name]
**Behavior:** [what it does]
**API Contract:** [endpoints, signatures]
**Edge Cases:** [what could go wrong]
**Acceptance Criteria:** [how to verify]

## Failure Handling
| Failure | Detection | Response | Recovery |
|---------|-----------|----------|----------|

## Environment Variables
| Variable | Purpose | Default |
|----------|---------|---------|

## Build Order

### Session 1: [Title]
**Branch:** feat/[kebab-case]
**Tag:** v0.1.0
**Depends on:** []
**Deliverables:**
- [ ] [item]
- [ ] Tests for deliverables

**Verification Gates:**
```bash
# [what this verifies]
[command]
```

**Quality Gates:**
```bash
# BLOCK: [description]
[command]
```

## Addendum
[Reserved for spec corrections during execution.]
SPEC
        echo -e "  ${GREEN}+${NC} .forge/TASKSPEC.md"
    else
        echo -e "  ${YELLOW}~${NC} .forge/TASKSPEC.md (exists)"
    fi

    # State file
    if [ ! -f "$STATE_FILE" ]; then
        cat > "$STATE_FILE" << 'STATE'
{
  "version": "3.0.0",
  "project": "",
  "spec_version": "v1.0",
  "sessions": []
}
STATE
        echo -e "  ${GREEN}+${NC} .forge/state.json"
    fi

    # CLAUDE.md in project root (not in .forge/)
    if [ ! -f "CLAUDE.md" ]; then
        cat > "CLAUDE.md" << 'CLAUDE'
# [Project Name]
[One-liner description]

## Commands
- Dev: ``
- Test: ``
- Lint: ``
- Build: ``

## Code Style
[Language-specific rules]

## Rules
- No raw DB errors exposed to clients
- URLs from env vars only
- No debug logging in committed code
- Feature branches, merge to dev
- Tests before merge
CLAUDE
        echo -e "  ${GREEN}+${NC} CLAUDE.md"
    else
        echo -e "  ${YELLOW}~${NC} CLAUDE.md (exists)"
    fi

    # Gitignore .forge/
    if [ -f ".gitignore" ]; then
        if ! grep -q "^\.forge/" .gitignore 2>/dev/null; then
            echo ".forge/" >> .gitignore
            echo -e "  ${GREEN}+${NC} Added .forge/ to .gitignore"
        fi
    else
        echo ".forge/" > .gitignore
        echo -e "  ${GREEN}+${NC} .gitignore (with .forge/)"
    fi

    echo ""
    echo -e "${GREEN}FORGE initialized.${NC}"
    echo -e "Next: edit ${BOLD}.forge/TASKSPEC.md${NC} — the spec is your most important investment."
    echo -e "Then: ${CYAN}forge audit${NC} (existing code) or ${CYAN}forge risk${NC} (greenfield)"
}

cmd_audit() {
    require_forge
    require_spec

    echo -e "${BOLD}Audit prompt:${NC}"
    echo ""
    cat << 'AUDIT_PROMPT'
============================================================
FORGE AUDIT — Paste into Claude Code or delegate to agent
============================================================

Read .forge/TASKSPEC.md completely. Walk every file in the codebase.

For EACH file produce:

### `path/to/file.ext`
**Verdict:** KEEP | PATCH | REWRITE | DELETE | UNCERTAIN
**Reason:** [one sentence]
**Failure:** [what this code got wrong — omit for KEEP]

Rules:
- Mark UNCERTAIN for any file you cannot fully read or assess.
- Do NOT write any code during the audit.
- Every file gets a verdict — no skipping.

After all verdicts:

## Scar Extraction
| ID | Category | Description | Severity |
|----|----------|-------------|----------|
| A1 | [category] | [concrete failure] | CRITICAL/HIGH/MEDIUM/LOW |

## Summary
- Total files: [N]
- KEEP: [N] | PATCH: [N] | REWRITE: [N] | DELETE: [N] | UNCERTAIN: [N]
- Recommended session ordering: [list]

Save output as .forge/AUDIT.md

============================================================
AUDIT_PROMPT
    echo ""
    echo -e "Save output to ${BOLD}.forge/AUDIT.md${NC}"
}

cmd_risk() {
    require_forge
    require_spec

    echo -e "${BOLD}Risk speculation prompt (greenfield):${NC}"
    echo ""
    cat << 'RISK_PROMPT'
============================================================
FORGE RISK SPECULATION — Paste into Claude Code or delegate
============================================================

Read .forge/TASKSPEC.md completely. No existing code — greenfield.

For EACH module/feature in the spec:

### Module: [name]
**Risk:** SIMPLE | MODERATE | COMPLEX | RISKY
**Rationale:** [why]
**Projected Failures:** [what could go wrong]
**Mitigation:** [how to prevent]
**Anti-Patterns:** [concrete things to avoid]

After all modules:

## Integration Risk Matrix
| Module A | Module B | Risk | Notes |
|----------|----------|------|-------|

## Scar Seeds
| ID | Category | Description | Severity |
|----|----------|-------------|----------|
| R1 | [category] | [projected failure] | [severity] |

## Recommended Session DAG
[Dependency graph with rationale]

Save output as .forge/RISK-SPECULATION.md

============================================================
RISK_PROMPT
    echo ""
    echo -e "Save output to ${BOLD}.forge/RISK-SPECULATION.md${NC}"
}

cmd_prompt() {
    local session_num="${1:-}"

    if [ -z "$session_num" ]; then
        echo -e "${RED}Usage: forge prompt <session_number>${NC}"
        exit 1
    fi

    require_forge
    require_spec

    local info
    info=$(get_session_info "$session_num")
    local title branch tag
    title=$(echo "$info" | cut -d'|' -f1)
    branch=$(echo "$info" | cut -d'|' -f2)
    tag=$(echo "$info" | cut -d'|' -f3)

    if [ -z "$title" ]; then
        echo -e "${RED}Session ${session_num} not found in TASKSPEC.md Build Order.${NC}"
        exit 1
    fi

    local session_dir="$SESSIONS_DIR/$(printf '%02d' "$session_num")-$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
    mkdir -p "$session_dir"

    echo -e "${BOLD}Session ${session_num}: ${title}${NC}"
    echo -e "  Branch: ${CYAN}${branch:-feat/[unset]}${NC}"
    echo -e "  Tag:    ${CYAN}${tag:-v[unset]}${NC}"
    echo ""

    cat << PROMPT_GEN
============================================================
FORGE SESSION PROMPT GENERATOR
Paste into orchestrator (Claude Chat) to generate the session prompt
============================================================

Read these files and generate a session prompt:

1. .forge/TASKSPEC.md — find Session ${session_num} in Build Order
2. .forge/AUDIT.md or .forge/RISK-SPECULATION.md — extract relevant scars
$(if [ "$session_num" -gt 1 ]; then
    echo "3. .forge/sessions/*/output.md — extract discoveries and scars from completed sessions"
fi)

Generate using this structure:

---

# ${title} -- [Project Name]

**Spec:** TASKSPEC.md v[version]
**Addendums applied:** [list or "none"]
**Completed sessions:** [list completed session titles]
**This session depends on:** [from Build Order]

## Mission
[from Build Order — what this session delivers]

## Deliverables
[from Build Order — checklist]

## Branch + Tag
- Branch: \`${branch:-feat/[from-spec]}\`
- Tag after merge: \`${tag:-v[from-spec]}\`

## Scar Load
### Critical (always loaded)
[any CRITICAL severity scars from audit + all prior sessions]

### From Audit/Risk (relevant to this session)
[HIGH/MEDIUM scars touching modules this session modifies]

### From Prior Sessions
[scars generated by completed sessions]

## Discoveries from Prior Sessions
[facts from prior session output reports]

## Constraints
[from CLAUDE.md rules]

## Anti-Patterns
[derived from scars — DO NOT / INSTEAD format]

## Verification Gates
[from Build Order — runnable commands]

## Quality Gates
[from Build Order — BLOCK/WARN level]

## Regression
Run the full test suite:
\`\`\`bash
[test command from CLAUDE.md]
\`\`\`

## Autonomous Execution Instructions
1. Create branch \`${branch:-feat/[name]}\` from \`dev\`
2. Implement all deliverables
3. Write tests for new functionality
4. Run verification gates — fix any failures
5. Run quality gates — BLOCK must pass, log WARN results
6. Run full test suite — fix any regressions
7. Commit with conventional messages (no session numbers, no FORGE terms)
8. Write session output report to .forge/sessions/$(printf '%02d' "$session_num")-[name]/output.md
9. If fix-forward fails twice, report BLOCKED with root cause

---

Save prompt to: ${session_dir}/prompt.md

============================================================
PROMPT_GEN

    echo ""
    echo -e "Save generated prompt to ${BOLD}${session_dir}/prompt.md${NC}"
}

cmd_gate() {
    local session_num="${1:-}"

    if [ -z "$session_num" ]; then
        echo -e "${RED}Usage: forge gate <session_number>${NC}"
        exit 1
    fi

    require_forge

    # Find session directory
    local session_dir
    session_dir=$(find "$SESSIONS_DIR" -maxdepth 1 -type d -name "$(printf '%02d' "$session_num")-*" 2>/dev/null | head -1)

    if [ -z "$session_dir" ] || [ ! -f "$session_dir/prompt.md" ]; then
        echo -e "${RED}No prompt found for session ${session_num}. Run 'forge prompt ${session_num}' first.${NC}"
        exit 1
    fi

    local prompt_file="$session_dir/prompt.md"
    echo -e "${BOLD}=== Verification Gates — Session ${session_num} ===${NC}"
    echo ""

    local in_verify=0
    local in_quality=0
    local in_regression=0
    local gate_count=0
    local pass_count=0
    local fail_count=0
    local warn_count=0

    while IFS= read -r line; do
        # Detect section boundaries
        if echo "$line" | grep -qi "## Verification Gates"; then
            in_verify=1; in_quality=0; in_regression=0
            echo -e "${CYAN}--- Verification Gates ---${NC}"
            continue
        fi
        if echo "$line" | grep -qi "## Quality Gates"; then
            in_verify=0; in_quality=1; in_regression=0
            echo -e "\n${CYAN}--- Quality Gates ---${NC}"
            continue
        fi
        if echo "$line" | grep -qi "## Regression"; then
            in_verify=0; in_quality=0; in_regression=1
            echo -e "\n${CYAN}--- Regression ---${NC}"
            continue
        fi
        if echo "$line" | grep -qiP "^## (Autonomous|Scar|Discover|Constraint|Anti|Mission|Deliver|Branch|Completion)"; then
            in_verify=0; in_quality=0; in_regression=0
            continue
        fi

        if [ $in_verify -eq 1 ] || [ $in_quality -eq 1 ] || [ $in_regression -eq 1 ]; then
            # Skip fences, comments, empty lines, markdown
            if echo "$line" | grep -qE '^\s*```|^\s*$|^\s*\*\*|^\s*-\s*\['; then
                continue
            fi
            # Detect BLOCK/WARN markers in comments
            local level="BLOCK"
            if echo "$line" | grep -qi "# WARN"; then
                level="WARN"
                continue
            fi
            if echo "$line" | grep -qi "# BLOCK"; then
                level="BLOCK"
                continue
            fi
            # Skip pure comment lines
            if echo "$line" | grep -qE '^\s*#'; then
                # Check if it sets level for next command
                if echo "$line" | grep -qi "warn"; then level="WARN"; fi
                continue
            fi
            # Lines that look like commands
            if echo "$line" | grep -qE '^\s*[a-zA-Z/\.]'; then
                gate_count=$((gate_count + 1))
                local cmd
                cmd=$(echo "$line" | sed 's/^\s*//' | sed 's/\s*#.*$//')
                echo -e "  ${BOLD}Gate ${gate_count}:${NC} $cmd"
                echo -n "  "

                if eval "$cmd" > /tmp/forge-gate-out.txt 2>&1; then
                    if [ "$level" = "WARN" ]; then
                        echo -e "${YELLOW}WARN${NC} (passed)"
                    else
                        echo -e "${GREEN}PASS${NC}"
                    fi
                    pass_count=$((pass_count + 1))
                else
                    if [ "$level" = "WARN" ]; then
                        echo -e "${YELLOW}WARN${NC} (failed — non-blocking)"
                        warn_count=$((warn_count + 1))
                    else
                        echo -e "${RED}FAIL${NC}"
                        head -3 /tmp/forge-gate-out.txt | sed 's/^/    /'
                        fail_count=$((fail_count + 1))
                    fi
                fi
                echo ""
            fi
        fi
    done < "$prompt_file"

    rm -f /tmp/forge-gate-out.txt

    echo -e "${BOLD}=== Results ===${NC}"
    echo -e "  Total: ${gate_count} | ${GREEN}Pass: ${pass_count}${NC} | ${RED}Fail: ${fail_count}${NC} | ${YELLOW}Warn: ${warn_count}${NC}"

    if [ $fail_count -eq 0 ] && [ $gate_count -gt 0 ]; then
        echo ""
        echo -e "${GREEN}All BLOCK gates passed.${NC}"
        if [ $warn_count -gt 0 ]; then
            echo -e "${YELLOW}${warn_count} WARN gate(s) flagged — review in session output.${NC}"
        fi
        echo -e "Next: ${CYAN}forge merge ${session_num}${NC}"
    elif [ $gate_count -eq 0 ]; then
        echo -e "\n${YELLOW}No gates found in prompt. Check Verification/Quality Gates sections.${NC}"
    else
        echo ""
        echo -e "${RED}BLOCK gates failed. Do NOT merge.${NC}"
        echo -e "Fix failures, then: ${CYAN}forge gate ${session_num}${NC}"
    fi
}

cmd_merge() {
    local session_num="${1:-}"

    if [ -z "$session_num" ]; then
        echo -e "${RED}Usage: forge merge <session_number>${NC}"
        exit 1
    fi

    require_forge
    require_spec

    local info
    info=$(get_session_info "$session_num")
    local title branch tag
    title=$(echo "$info" | cut -d'|' -f1)
    branch=$(echo "$info" | cut -d'|' -f2)
    tag=$(echo "$info" | cut -d'|' -f3)

    if [ -z "$branch" ]; then
        echo -e "${RED}No branch found for session ${session_num} in TASKSPEC.md.${NC}"
        exit 1
    fi

    echo -e "${BOLD}Merging session ${session_num}: ${title}${NC}"
    echo -e "  Branch: ${CYAN}${branch}${NC} -> ${CYAN}dev${NC}"
    echo -e "  Tag:    ${CYAN}${tag}${NC}"
    echo ""

    # Check branch exists
    if ! git rev-parse --verify "$branch" > /dev/null 2>&1; then
        echo -e "${RED}Branch '${branch}' not found.${NC}"
        exit 1
    fi

    # Check we're on dev or switch to it
    local current_branch
    current_branch=$(git branch --show-current)
    if [ "$current_branch" != "dev" ]; then
        echo -e "  Switching to dev..."
        git checkout dev
    fi

    # Merge
    echo -e "  Merging ${branch}..."
    if git merge "$branch" --no-ff -m "feat: merge ${title,,}"; then
        echo -e "  ${GREEN}Merged.${NC}"
    else
        echo -e "  ${RED}Merge conflict. Resolve manually, then re-run.${NC}"
        exit 1
    fi

    # Tag
    if [ -n "$tag" ] && [ "$tag" != "(tagged after merge session)" ]; then
        git tag -a "$tag" -m "${title}"
        echo -e "  ${GREEN}Tagged ${tag}${NC}"
    fi

    # Update state
    if [ -f "$STATE_FILE" ]; then
        python3 -c "
import json
with open('$STATE_FILE') as f:
    state = json.load(f)
found = False
for s in state.get('sessions', []):
    if s.get('num') == ${session_num}:
        s['status'] = 'merged'
        found = True
        break
if not found:
    state.setdefault('sessions', []).append({
        'num': ${session_num},
        'title': '${title}',
        'branch': '${branch}',
        'tag': '${tag}',
        'status': 'merged'
    })
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
" 2>/dev/null || true
    fi

    echo ""
    echo -e "${GREEN}Session ${session_num} merged and tagged.${NC}"
    echo -e "Next: ${CYAN}forge prompt $((session_num + 1))${NC}"
}

cmd_status() {
    require_forge

    echo -e "${BOLD}=== FORGE Project Status ===${NC}"
    echo ""

    # Spec
    if [ -f "$FORGE_DIR/TASKSPEC.md" ]; then
        local session_count
        session_count=$(grep -c "^### Session" "$FORGE_DIR/TASKSPEC.md" 2>/dev/null || echo "0")
        echo -e "  ${GREEN}*${NC} TASKSPEC.md (${session_count} sessions in Build Order)"
    else
        echo -e "  ${RED}x${NC} TASKSPEC.md missing"
    fi

    # Audit
    if [ -f "$FORGE_DIR/AUDIT.md" ]; then
        echo -e "  ${GREEN}*${NC} AUDIT.md"
    elif [ -f "$FORGE_DIR/RISK-SPECULATION.md" ]; then
        echo -e "  ${GREEN}*${NC} RISK-SPECULATION.md (greenfield)"
    else
        echo -e "  ${YELLOW}~${NC} No audit or risk report"
    fi

    # Sessions
    echo ""
    echo -e "  ${BOLD}Sessions:${NC}"
    local found_sessions=0
    shopt -s nullglob
    for d in "$SESSIONS_DIR"/*/; do
        if [ -d "$d" ]; then
            found_sessions=1
            local dirname
            dirname=$(basename "$d")
            local has_prompt="" has_output="" status_icon="${YELLOW}~"

            [ -f "$d/prompt.md" ] && has_prompt="prompt"
            [ -f "$d/output.md" ] && has_output="output"

            if [ -n "$has_output" ]; then
                # Check verdict in output
                local verdict
                verdict=$(grep -oP "VERDICT:\s*\K\w+" "$d/output.md" 2>/dev/null || echo "")
                case "$verdict" in
                    PROCEED) status_icon="${GREEN}PROCEED" ;;
                    REVIEW)  status_icon="${YELLOW}REVIEW" ;;
                    BLOCKED) status_icon="${RED}BLOCKED" ;;
                    *)       status_icon="${BLUE}done" ;;
                esac
            elif [ -n "$has_prompt" ]; then
                status_icon="${BLUE}prompted"
            fi

            echo -e "    ${dirname}: ${status_icon}${NC}"
        fi
    done
    if [ $found_sessions -eq 0 ]; then
        echo -e "    ${DIM}No sessions yet${NC}"
    fi

    # Git info
    if git rev-parse --git-dir > /dev/null 2>&1; then
        echo ""
        echo -e "  ${BOLD}Git:${NC}"
        local current_branch
        current_branch=$(git branch --show-current 2>/dev/null || echo "detached")
        echo -e "    Branch: ${CYAN}${current_branch}${NC}"
        local tag_count
        tag_count=$(git tag -l "v*" 2>/dev/null | wc -l)
        if [ "$tag_count" -gt 0 ]; then
            local latest_tag
            latest_tag=$(git tag -l "v*" --sort=-v:refname 2>/dev/null | head -1)
            echo -e "    Latest tag: ${CYAN}${latest_tag}${NC} (${tag_count} total)"
        fi
    fi

    echo ""
}

cmd_scar() {
    local subcmd="${1:-}"
    shift || true

    require_forge

    case "$subcmd" in
        add)
            local text="$*"
            if [ -z "$text" ]; then
                echo -e "${RED}Usage: forge scar add <description>${NC}"
                exit 1
            fi

            # Append to scars in state
            local id
            id="M$(date +%s | tail -c 5)"
            python3 -c "
import json
with open('$STATE_FILE') as f:
    state = json.load(f)
state.setdefault('scars', []).append({
    'id': '${id}',
    'category': 'MANUAL',
    'description': '''${text}''',
    'severity': 'MEDIUM'
})
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
" 2>/dev/null
            echo -e "${GREEN}Scar ${id} added.${NC}"
            ;;
        prune)
            if [ ! -f "$FORGE_DIR/AUDIT-SCARS.md" ]; then
                cat > "$FORGE_DIR/AUDIT-SCARS.md" << 'ARCHIVE'
# Archived Scars

**Last Pruned:** $(date +%Y-%m-%d)
**Policy:** Last two sessions + CRITICAL stay active. Rest archived here.
ARCHIVE
            fi
            echo -e "${YELLOW}Move old scars to .forge/AUDIT-SCARS.md${NC}"
            echo "Keep: last 2 sessions + CRITICAL. Archive everything else."
            ;;
        *)
            echo -e "${RED}Usage: forge scar <add|prune>${NC}"
            ;;
    esac
}

cmd_validate() {
    require_forge
    require_spec

    echo -e "${BOLD}Validating .forge/TASKSPEC.md...${NC}"
    local errors=0
    local spec="$FORGE_DIR/TASKSPEC.md"

    # Required sections
    for section in "## Provenance" "## Mission" "## Stack" "## Directory Structure" "## Data Model" "## Features" "## Build Order"; do
        if grep -q "$section" "$spec"; then
            echo -e "  ${GREEN}*${NC} ${section}"
        else
            echo -e "  ${RED}x${NC} ${section} -- MISSING"
            errors=$((errors + 1))
        fi
    done

    # Check sessions have required fields
    local session_count
    session_count=$(grep -c "^### Session" "$spec" 2>/dev/null || echo "0")
    echo ""
    echo -e "  Sessions: ${BOLD}${session_count}${NC}"

    # Check branch fields
    local branch_count
    branch_count=$(grep -c "\*\*Branch:\*\*" "$spec" 2>/dev/null || echo "0")
    if [ "$branch_count" -lt "$session_count" ]; then
        echo -e "  ${RED}x${NC} Some sessions missing Branch: field"
        errors=$((errors + 1))
    else
        echo -e "  ${GREEN}*${NC} All sessions have Branch: field"
    fi

    # Check tag fields
    local tag_count
    tag_count=$(grep -c "\*\*Tag:\*\*" "$spec" 2>/dev/null || echo "0")
    if [ "$tag_count" -lt "$session_count" ]; then
        echo -e "  ${RED}x${NC} Some sessions missing Tag: field"
        errors=$((errors + 1))
    else
        echo -e "  ${GREEN}*${NC} All sessions have Tag: field"
    fi

    # Check verify blocks
    local verify_count
    verify_count=$(grep -c "Verification Gates" "$spec" 2>/dev/null || echo "0")
    if [ "$verify_count" -lt "$session_count" ]; then
        echo -e "  ${RED}x${NC} Some sessions missing Verification Gates"
        errors=$((errors + 1))
    else
        echo -e "  ${GREEN}*${NC} All sessions have Verification Gates"
    fi

    echo ""
    if [ $errors -eq 0 ]; then
        echo -e "${GREEN}Spec valid.${NC}"
    else
        echo -e "${RED}${errors} issue(s). Fix before generating prompts.${NC}"
    fi
}

cmd_version() {
    echo "FORGE v${FORGE_VERSION}"
}

# Main dispatch
case "${1:-}" in
    init)       shift; cmd_init "$@" ;;
    audit)      cmd_audit ;;
    risk)       cmd_risk ;;
    prompt)     shift; cmd_prompt "$@" ;;
    gate)       shift; cmd_gate "$@" ;;
    merge)      shift; cmd_merge "$@" ;;
    status)     cmd_status ;;
    scar)       shift; cmd_scar "$@" ;;
    validate)   cmd_validate ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|"") usage ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        usage
        exit 1
        ;;
esac
